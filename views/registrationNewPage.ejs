<%- include("partials/head", { pageTitle, shellClass: "site-shell-public" }) %>
<%- include("partials/publicNav") %>

<section class="page-header">
  <div class="shell-section">
    <div class="page-header-grid">
      <span class="eyebrow">Registration form</span>
      <h1 class="page-title">Reserve your place for <%= event.title %>.</h1>
      <p class="page-copy">
        Your account details will be used automatically. Choose how many seats you
        want, and Event Hub will only confirm the request when enough slots remain.
      </p>
    </div>
    <%- include("partials/message", { message, errorMessage: "" }) %>
  </div>
</section>

<section class="utility-section">
  <div class="shell-section">
    <div class="detail-grid">
      <div class="detail-panel">
        <span class="eyebrow">Event snapshot</span>
        <h2 class="detail-title"><%= event.title %></h2>
        <p class="detail-copy"><%= event.description %></p>

        <div class="detail-list">
          <div class="detail-list-item">
            <span class="detail-label">Registered User</span>
            <span class="detail-value"><%= currentUserName %> (<%= currentUserEmail %>)</span>
          </div>
          <div class="detail-list-item">
            <span class="detail-label">Date</span>
            <span class="detail-value"><%= formatDate(event.date) %></span>
          </div>
          <div class="detail-list-item">
            <span class="detail-label">Location</span>
            <span class="detail-value"><%= event.location %></span>
          </div>
          <div class="detail-list-item">
            <span class="detail-label">Available Slots</span>
            <span class="detail-value"><%= event.availableSlots %></span>
          </div>
        </div>
      </div>

      <div class="admin-form-shell">
        <%- include("partials/message", { message: "", errorMessage }) %>

        <form action="/events/<%= event._id %>/register" method="POST">
          <div class="form-grid">
            <div class="form-group form-group-full">
              <label class="label" for="ticketCount">Seat Count</label>
              <input
                class="input"
                id="ticketCount"
                name="ticketCount"
                type="number"
                min="1"
                max="<%= maxSeatCount %>"
                required
                value="<%= formData.ticketCount %>"
              />
              <p class="input-help">
                You can save up to <strong><%= maxSeatCount %></strong> seat(s) for
                this event.
              </p>
            </div>
          </div>

          <div class="form-actions">
            <button class="button-primary" type="submit">Add To My Calendar</button>
            <a class="button-secondary" href="/events/<%= event._id %>">Back To Event</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
